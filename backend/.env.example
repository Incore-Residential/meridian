# Server
PORT=3000

# Comma-separated list of allowed origins for CORS. Use "*" to allow all (dev only).
CORS_ORIGIN=http://localhost:8000

# Resend (https://resend.com) — required for the contact form
RESEND_API_KEY=re_your-resend-key-here

# Contact form: who emails are sent from / to
# from must be a verified Resend domain (use onboarding@resend.dev for testing)
CONTACT_FROM_EMAIL=onboarding@resend.dev
CONTACT_TO_EMAIL=mlich@incoreresidential.com
